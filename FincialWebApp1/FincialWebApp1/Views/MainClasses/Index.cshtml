<div class="tg-sihp-printon-print print-onpaper " style="height: 100%; width:100%;direction: rtl; text-align: left; overflow: auto;">
    @{
    Pager pager = new Pager();

    int pageN0 = 0;
    int startPage = Math.Max(ViewBag.Pager.CurrentPage - 2, 1);
    int endPage = Math.Min(ViewBag.Pager.CurrentPage + 2, ViewBag.Pager.TotalPages);


    @if (ViewBag.Pager.CurrentPage > 1)
    {
        @Html.ActionLink("First", "Index", new { pg = 1, /* other parameters */ }) <span></span>
        @Html.ActionLink("Prev", "Index", new { pg = ViewBag.Pager.CurrentPage - 1, /* other parameters */ })

        <span></span>
    }

    for (int i = startPage; i <= endPage; i++)
    {
        if (i == ViewBag.Pager.CurrentPage)
        {
            @:<text>@i</text>
        }
        else
        {
            @Html.ActionLink(i.ToString(), "Index", new {
           pg = i,
           SearchCTNum = ViewBag.SearchCTNum,
           SearchBankName = ViewBag.SearchBankName,
           SearchPreparationAuthority = ViewBag.SearchPreparationAuthority,
           SearchDepotName = ViewBag.SearchDepotName,
           SearchFormCuttingNumber = ViewBag.SearchFormCuttingNumber,
           SearchProductType = ViewBag.SearchProductType,
           SearchCutAmount = ViewBag.SearchCutAmount,
           startDateCT = ViewBag.startDateCT,
           endDateCT = ViewBag.endDateCT,
           startDate = ViewBag.startDate,
           endDate = ViewBag.endDate,
           startDateCheack = ViewBag.startDateCheack,
           endDateCheack = ViewBag.endDateCheack,
           IsCheacked = ViewBag.IsCheacked
           /* other parameters */
       })

            <span></span>
        }
    }

    @if (ViewBag.Pager.CurrentPage < ViewBag.Pager.TotalPages)
    {
        @Html.ActionLink("Next", "Index", new { pg = ViewBag.Pager.CurrentPage + 1, /* other parameters */ })

        <span></span>
        @Html.ActionLink("Last", "Index", new { pg = ViewBag.Pager.TotalPages, /* other parameters */ })

        <span></span>
    }


    }
