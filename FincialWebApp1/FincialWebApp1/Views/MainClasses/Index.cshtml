        <button id="printButton" onclick="printPage()" class="btn btn-primary"><i class="bi bi-printer-fill"></i> &nbsp;طباعة  </button>
        <button class="btn btn-secondary  "><i class="bi bi-arrow-repeat"></i>&nbsp; Refresh </button>
        }
    </form>
</div>
   
