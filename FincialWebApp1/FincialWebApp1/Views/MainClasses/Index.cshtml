@using FinancialWebApp1.Models;
@using Microsoft.AspNetCore.Identity;
@inject SignInManager<IdentityUser> signInManager;
@model IEnumerable<FinancialWebApp1.Models.MainClass>

@{
    ViewData["Title"] = "البيانات";
}



<head>

<link rel="stylesheet" href="~/css/MainIndexStyle.css" />
<link rel="stylesheet" href="~/css/TableStyle.Css" />
<link rel="stylesheet" href="~/css/print.css" />
<link rel="stylesheet" href="~/css/Site2.css" />

<style>
    /* Adjust the size of the content area */
    .content {
        min-width:500px;
        min-height: 500px; /* Set a minimum height for the content area */
        overflow: auto; /* Add scrollbars if the content exceeds the height */
    }

        .yellow-row {
            background-color: yellow; /* Change this to the desired background color */
        }
</style>
