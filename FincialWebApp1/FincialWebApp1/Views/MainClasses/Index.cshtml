        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <script>
            $(document).ready(function () {
                // Toggle checkboxes based on server data
                $(".toggle-checkbox").each(function () {
                    var itemId = $(this).data("id");
                    var isChecked = $(this).data("ischecked");

                    if (isChecked) {
                        $(this).prop("checked", true);
                    }
                });

                // Handle checkbox changes
                $(".toggle-checkbox").change(function () {
                    var itemId = $(this).data("id");
                    var isChecked = $(this).prop("checked");

                    // Send AJAX request to update server
                    $.ajax({
                        type: "POST",
                        url: "/MainClasses/UpdateBoolean",
                        data: { id: itemId, isChecked: isChecked },
                        success: function (data) {
                            // Update checkbox state based on server response
                            if (data.success) {
                                // Update the checkbox state
                                $(".toggle-checkbox[data-id='" + itemId + "']").prop("checked", isChecked);
                            } else {
                                // Handle error scenario if needed
                            }
                        },
                        error: function () {
                            // Handle error if needed
                        }
                    });
                });
            });
        </script>
