<body style="display:contents">
<div class="no-Display on-print">
    <div>
    </div>
    <div  style="text-align:center;font-weight: bold; ">  وزارة النفط </div>
    <div  style="text-align:center;font-weight: bold;">شركة توزيع المنتجات النفطية/هيأة توزيع بغداد</div>
    <div  style="text-align:center;font-weight: bold;">تفاصل المبيعات اليومية للزيوت والوقود  </div>
</div>


    <div style="margin-top:2%;">
    <form class="no-print" style="direction:rtl;padding-bottom:2%" class="form-inline">
        @if (signInManager.IsSignedIn(User) && (User.IsInRole("Super Admin")))
        {
            <button class="btn btn-danger" asp-controller="MainClasses" asp-action="DeletedRecords"><i class="bi bi-trash"></i>&nbsp;البيانات المحذوفة</button>

        }
         @if (signInManager.IsSignedIn(User) && (User.IsInRole("Super Admin") || User.IsInRole("Admin") || User.IsInRole("Checking")))
        {
            <button class="btn" style="background-color:aqua;" asp-controller="Administrator" asp-action="Track"><i class="bi bi-eye-fill"></i>&nbsp;حركة المستخدمين&nbsp;</button>
             <button class="btn" style="background-color:crimson;" asp-controller="MainClasses" asp-action="Dashboard"><i class="bi bi-eye-fill"></i>&nbsp;Dashboard &nbsp;</button>
        }
        @if (signInManager.IsSignedIn(User) && (User.IsInRole("Super Admin") || User.IsInRole("Epay")))
            {
             <button class="btn  btn-success " asp-action="ImportExcel"><i class="bi bi-arrow-bar-up"></i>&nbsp;رفع بيانات  </button>
            <button class="btn btn-warning " asp-action="Create"><i class="bi bi-bookmark-plus"></i>&nbsp;أضافة جديدة</button>
            <button class="btn btn-light" asp-controller="BankLists" asp-action="Index"><i class="bi bi-bookmark-plus"></i>&nbsp;المصارف</button>

        }
            @if (signInManager.IsSignedIn(User) && (User.IsInRole("Super Admin") || User.IsInRole("Epay") || User.IsInRole("Cutting") || User.IsInRole("Admin") || User.IsInRole("Checking")))
        {
